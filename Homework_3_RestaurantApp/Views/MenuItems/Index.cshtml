@model IEnumerable<RestaurantMenuApp.Models.MenuItem>

<h2>Список блюд</h2>
<p><a asp-action="Create" class="btn btn-primary">Добавить блюдо</a></p>
<table class="table">
    <thead>
        <tr><th>Название блюда</th><th>Ресторан</th><th>Цена (руб.)</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Restaurant?.Name</td>
                <td>@item.Price.ToString("N2")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Изменить</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Удалить</a>
                 </td>
            </tr>
        }
    </tbody>
</table>
